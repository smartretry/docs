  "keyFeatures": [
    "Intelligent retry engine that rebuilds failed transactions with optimized parameters",
    "Multi-acquirer dynamic routing based on real-time performance signals",
    "3DS optimization with ECI prediction and PSD2 exemption handling",
    "Recurring payment management with platform-managed or merchant-managed scheduling",
    "Pre-auth, capture, refund, and void transaction lifecycle support",
    "BIN intelligence and issuer-side behavioral analytics",
    "Performance-based pricing — charges only on successfully recovered transactions",
    "Sandbox environment for safe integration testing"
  ],

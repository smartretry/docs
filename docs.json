{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "SmartRetry",
  "colors": {
    "primary": "#fc34a4",
    "light": "#f094d4"
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/images/logo.svg",
    "dark": "/images/logo.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/smartretry"
    },
    "links": [
      {
        "label": "Status",
        "href": "https://status.smartretry.com/"
      },
      {
        "label": "Contact",
        "href": "https://www.smartretry.com/contact"
      }
    ]
  },
  "footer": {
    "socials": {
      "website": "https://www.smartretry.com/",
      "linkedin": "https://www.linkedin.com/company/smartretry/",
      "facebook": "https://www.facebook.com/smartretry",
      "youtube": "https://www.youtube.com/@SmartRetry",
      "instagram": "https://www.instagram.com/smartretry/",
      "x": "https://x.com/smartretry"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "index",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/how-it-works",
              "concepts/transaction-types",
              "concepts/transaction-statuses",
              "concepts/decline-codes",
              "concepts/recurring-payments"
            ]
          },
          {
            "group": "Integration",
            "pages": [
              "integration/rest-api",
              "integration/sdks",
              "integration/postman",
              "integration/webhooks",
              "integration/terminals",
              "integration/payment-methods",
              "integration/sandbox"
            ]
          },
          {
            "group": "Release Notes",
            "pages": [
              "changelog"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/overview",
              "api-reference/idempotency",
              "api-reference/rate-limiting",
              "api-reference/errors",
              "api-reference/health"
            ]
          },
          {
            "group": "Payments",
            "pages": [
              "api-reference/payments/sale",
              "api-reference/payments/preauth",
              "api-reference/payments/capture",
              "api-reference/payments/refund",
              "api-reference/payments/void",
              "api-reference/payments/status"
            ]
          },
          {
            "group": "Recurring",
            "pages": [
              "api-reference/recurring/init",
              "api-reference/recurring/status",
              "api-reference/recurring/charge",
              "api-reference/recurring/update",
              "api-reference/recurring/cancel"
            ]
          },
          {
            "group": "Future Transactions",
            "pages": [
              "api-reference/future-transactions/status",
              "api-reference/future-transactions/update",
              "api-reference/future-transactions/charge",
              "api-reference/future-transactions/cancel"
            ]
          }
        ]
      }
    ]
  }
}
